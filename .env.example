# Razorpay API keys (Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Razorpay Webhook secret (set when you create the webhook in Dashboard > Webhooks)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Google Sheets
# Full JSON key content of your Google service account, as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# The ID from your Google Sheet's URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your-google-sheet-id
